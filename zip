# Sub-commands
case "${1:-}" in
    build)
        case "${2:-}" in
            rust)
                echo -e "${BLUE}[BUILD] Rust/Tokio API...${NC}"
                cd "$HOME/titan-mesh/titan-tokio-api" && cargo build --release
                ;;
            kotlin)
                echo -e "${BLUE}[BUILD] Kotlin/Ktor Gateway...${NC}"
                cd "$HOME/titan-mesh/titan-ktor-gateway" && \
                    bash gradlew_bootstrap.sh && ./gradlew buildFatJar
