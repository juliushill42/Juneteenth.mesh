cat > "$PREFIX/bin/titan-stop" << 'STOPEOF'
#!/usr/bin/env bash
bash "$HOME/titan-mesh/titan-stop.sh"
STOPEOF
chmod +x "$PREFIX/bin/titan-stop"

echo "Done. Type: titan"
