check() {
    local name="$1" cmd="$2"
    if command -v "$cmd" &>/dev/null; then
        echo -e "  ${GREEN}[‚úď]${NC} $name $(${cmd} --version 2>/dev/null | head -1 | grep -oP '\d+\.\d+[\.\d]*' | head -1)"
