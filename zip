svc_check() {
    local name="$1" port="$2"
    if curl -sf --max-time 1 "http://127.0.0.1:$port/health" &>/dev/null; then
        echo -e "  ${GREEN}[‚Ė≤ LIVE]${NC}  $name :$port"
    else
        echo -e "  ${RED}[‚Ėľ OFF ]${NC}  $name :$port"
    fi
